# ---------------------------------------------------------------------------
# Environment variables template — copy to `.env.local` and fill in values.
# All NEXT_PUBLIC_* variables are exposed to the browser.
# ---------------------------------------------------------------------------

# Public site URL (used for SEO, canonical URLs, sitemap & Open Graph)
NEXT_PUBLIC_SITE_URL=https://arindajoseph.vercel.app

# Contact form provider (optional).
# If set, the contact form POSTs to https://formspree.io/f/<ID>.
# Leave blank to run the form in demo mode (simulated success).
NEXT_PUBLIC_FORMSPREE_ID=
